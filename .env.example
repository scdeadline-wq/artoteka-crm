# Database
POSTGRES_USER=artoteka
POSTGRES_PASSWORD=artoteka_secret
POSTGRES_DB=artoteka
DATABASE_URL=postgresql+asyncpg://artoteka:artoteka_secret@localhost:5432/artoteka

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO (S3-compatible storage)
MINIO_ROOT_USER=artoteka
MINIO_ROOT_PASSWORD=artoteka_secret
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=artoteka
S3_SECRET_KEY=artoteka_secret
S3_BUCKET=artoteka-images

# JWT
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-bot-token-here
